# Phila  environment
# Part A runs entirely on mock data and needs NONE of these. They light up in Part B.

# Data provider seam (Phase 0). "mock" (default) or "db" (Phase 10+).
DATA_PROVIDER=mock

# Neon Postgres connection (Phase 10). EU region is fine for early Part B; migrate to an
# SA region (AWS af-south-1 / Azure SA North) before public launch with real client PII.
# Owner role  used by migrations, seed, and Better Auth (has BYPASSRLS).
# DATABASE_URL=postgres://user:password@host/db?sslmode=require

# Non-owner application role (Phase 10.2, RLS). Same host/db as DATABASE_URL but the
# `phila_app` role (no BYPASSRLS), so Row-Level Security is enforced. Used by the RLS
# proof test and (after the runtime cutover) the request path. Apply policies: npm run db:rls
# DATABASE_URL_APP=postgres://phila_app:password@host/db?sslmode=require

# Field-level encryption key (Phase 10). base64-encoded 32 bytes. REQUIRED in production 
# a missing key is fatal; Phila never stores special-category data as plaintext.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# PHILA_FIELD_KEY=

# Better Auth secret (Phase 9).
# BETTER_AUTH_SECRET=
# BETTER_AUTH_URL=http://localhost:3000

# Notifications (Phase 12). Dormant until set  nothing sends without these.
# Phila's platform SMS (BulkSMS) + email (Resend) credentials; WhatsApp is BYO per org.
# PHILA_BULKSMS_TOKEN_ID=
# PHILA_BULKSMS_TOKEN_SECRET=
# RESEND_API_KEY=
# PHILA_EMAIL_FROM=notifications@phila.co.za   # a verified sending domain
# CRON_SECRET=                                  # Bearer token to protect /api/cron/reminders

# Video  LiveKit (Phase 13 · admin-managed in 17.1). NOT env vars: the super-admin
# picks Demo (self-host, docker-compose.livekit.yml, dev keys devkey/secret) or Live
# (LiveKit Cloud), pastes the ws URL + key + secret, tests, and switches it on in
# /admin/integrations (encrypted at rest). Seeded in Demo mode. See docs/LIVEKIT_SETUP.md.

# Payments  Paystack (Phase 15). NOT an env var: the super-admin pastes the secret
# key, tests the connection, and switches it on in /admin/integrations (encrypted at
# rest). Use a TEST key (sk_test_…) to trial the full checkout for free. Webhook:
# point Paystack → /api/webhooks/paystack. AI providers + each org's own gateway are
# configured in-app the same way.
